# Resend (https://resend.com) — required for form emails
RESEND_API_KEY=

# Verified sender, e.g. Same Day Home Buyer <hello@yourdomain.com>
# Must use a domain verified in Resend (or onboarding@resend.dev for testing).
# IMPORTANT: With onboarding@resend.dev, Resend only delivers to addresses on your account
# (often your signup email). For any inbox, verify your domain and set FROM to that domain.
RESEND_FROM_EMAIL=

# Inbox that receives valuation + referral leads
LEAD_INBOX_EMAIL=
